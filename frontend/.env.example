# Frontend env (Vite). Copy to `.env` (or `.env.local`) to override.
# Only VITE_-prefixed vars are exposed to the browser bundle.

# Dev-server proxy target for /api/* (see vite.config.ts).
VITE_API_TARGET=http://127.0.0.1:8000

# --- "Project Template" (pre-configured PKI) defaults --------------------
# Site-specific values baked into the landing page's PKI starter topology
# (src/lib/projectTemplate.ts). Change here rather than in code. The password
# must satisfy the AD-complexity policy (>=12 chars, >=3 char classes) and is a
# throwaway lab credential — replace it for anything real.
VITE_PKI_DOMAIN_NAME=encon.pki
VITE_PKI_NETBIOS_NAME=ENCON
VITE_PKI_FOREST_LEVEL=Windows Server 2016
VITE_PKI_DOMAIN_ADMIN_PASSWORD=EcPkiLab#2026Key
VITE_PKI_ROOT_CA_CN=EC-Root-CA
VITE_PKI_ISSUING_CA_CN=EC-Issuing-CA
VITE_PKI_CPS_URL=http://pki.encon.pki/cps.txt
VITE_PKI_KEY_ALGORITHM=ML-DSA-87

# Guest-share URL for the landing page's ready-to-use, already deployed lab.
# Publish the designated project once, then paste its generated link here.
VITE_PREDEPLOYED_PKI_LINK=/?share=predeployed-pki
