# EC-PKI-Playground backend configuration
# Copy this file to .env and fill in the values for your deploy.
#
# Login is always required — there is no anonymous mode. Every visitor signs
# in with an account (identity is decoupled from the ESXi target):
#   - Username/password (POST /auth/login; bootstrap the first operator with
#     uv run create-admin <name>). Guests sign in exclusively this way.
#   - Employee SSO (OIDC_* vars below).
# The account's role (operator/guest) decides the feature set.

# Example guest account, seeded into the users collection at startup if absent
# (idempotent — never overwrites an existing account). Gives a fresh deploy a
# working username/password login out of the box. Change these for any real
# deploy; set the password empty to skip seeding entirely.
# EXAMPLE_GUEST_USERNAME=guest
# EXAMPLE_GUEST_PASSWORD=guest-playground

# Required in BOTH the API and Celery worker processes.
# Generate each with: openssl rand -base64 32
# SESSION_SECRET=
# SETTINGS_ENC_KEY=

# First-boot seed for the shared org-wide ESXi target. Written into the Mongo
# settings document if absent there; afterwards the document is authoritative
# and operator-editable via PUT /api/settings without a restart. Optional at
# boot — VM routes 503 until it's configured.
# ESXI_HOST=192.168.100.10
# ESXI_USER=root
# ESXI_PASSWORD=changeme
# ESXI_PORT=443

# First-boot seed for the guest subnet — same seed-only semantics
# as ESXI_*; operator-editable via PUT /api/settings afterwards (edits reseed
# the IP pool live). Every real deploy-plan clone claims an address from the
# inclusive GUEST_IP_START..GUEST_IP_END range and bakes it into the VM's
# firstboot ISO; teardown (DELETE /api/vm/{name}) returns it to the pool.
# The range must exclude the network, broadcast, and gateway addresses.
# Deploys are rejected (422) until start/end/gateway/dns1 are all configured.
# GUEST_IP_START=192.168.100.50
# GUEST_IP_END=192.168.100.199
# GUEST_PREFIX=24
# GUEST_GATEWAY=192.168.100.1
# GUEST_DNS1=192.168.100.2
# GUEST_DNS2=
# GUEST_DNS_SUFFIX=pki.lab

# Employee SSO — generic OIDC code flow (Keycloak and Azure AD both fit).
# Enabled only when issuer, client id/secret, and redirect URI are all set.
# IdP groups map to roles via the two *_GROUPS lists (comma-separated, exact
# string match against the OIDC_GROUP_CLAIM claim); users matching no group
# are rejected.
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:5173/
# OIDC_GROUP_CLAIM=groups
# OIDC_OPERATOR_GROUPS=
# OIDC_GUEST_GROUPS=

# MongoDB — system of record for projects / VM registry / IP pool / settings
# doc / users. The app fails fast at startup if it can't reach it. Run one
# locally with:
#   docker run -d --name pki-mongo -p 27017:27017 -v pki-mongo-data:/data/db mongo:8
# MONGO_URL=mongodb://localhost:27017
# MONGO_DB=pki_playground

# Valkey/Redis — Celery broker, result backend, and the job pub/sub bus the
# progress WebSockets read from.
# VALKEY_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Orchestrator agent bundling. Set BOTH to embed the pki-orchestrator
# agent into every firstboot ISO so deployed VMs phone home. Read on the WORKER
# host. Unset → the firstboot ISO stays agent-free.
#   ORCHESTRATOR_AGENT_PATH — worker-host path to the agent binary.
#   BACKEND_PUBLIC_URL — origin a booted VM dials home to, baked into the
#     agent's orchestrator.toml as [backend] url. For VMs that can't reach the
#     backend directly, point this at a Cloudflare tunnel (cloudflared proxies
#     the WebSocket at {BACKEND_PUBLIC_URL}/api/orchestrator/connect).
# ORCHESTRATOR_AGENT_PATH=/opt/pki-playground/agent/pki-orchestrator.exe
# BACKEND_PUBLIC_URL=https://pki-lab.4rc.tech

# How long (seconds) the clone worker waits for a freshly-booted VM's agent to
# phone home before failing the provision op. Role/feature installs run as
# dispatched steps after phone-home (not in firstboot), so a healthy VM connects
# within minutes; this is the ceiling for a slow boot. Default 2700 (45 min).
# AGENT_PHONE_HOME_TIMEOUT_S=2700

# How long (seconds) the agent connection must stay stable — liveness present
# and no reconnect — before the worker begins dispatching provisioning. A fresh
# clone phones home during an intermediate firstboot boot and then reboots once
# more to finalize its hostname; this dwell rides through that finalize reboot so
# provisioning isn't dispatched into an agent about to die. Must exceed the 90s
# agent liveness TTL plus the intermediate-boot window. Default 180 (3 min).
# AGENT_BOOT_SETTLE_S=180
