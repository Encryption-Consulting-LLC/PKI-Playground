# EC-PKI-Playground backend configuration
# Copy this file to .env and fill in the values for your deploy.
#
# Two deploy modes:
#
#   login (internal / operator)
#     - Operators supply ESXi credentials at login via POST /auth/connect.
#     - Backend-provided ESXI_* vars are NOT used.
#     - Keep this deploy on the private network only.
#
#   guest (public playground)
#     - The backend auto-connects to the ESXi host using the vars below.
#     - No client-supplied credentials are accepted (POST /auth/connect → 403).
#     - The ESXI_* credentials are effectively handed to every visitor,
#       so the target host MUST be a throwaway, network-isolated ESXi.
#     - This is the only deploy that should be internet-facing.

AUTH_MODE=login

# Required when AUTH_MODE=guest — ignored (and not needed) in login mode:
# ESXI_HOST=192.168.100.10
# ESXI_USER=root
# ESXI_PASSWORD=changeme
# ESXI_PORT=443
